<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=, initial-scale=1.0">
    <title>View User</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</head>

<body>
    <div style="width: 600px; margin: auto;">
        <h1 style="padding: 10px 0;">View detail a user <%= user.id %>
        </h1>
        <form action="/handle-update-user" method="POST">
            <input style="display: none;" name="id" value="<%= user.id %>" />
            <div class="mb-3">
                <label for="exampleFormControlInput1" class="form-label">Name</label>
                <input value="<%= user.name %>" type="text" name="name" class="form-control"
                    id="exampleFormControlInput1" placeholder="your name">
            </div>
            <div class="mb-3">
                <label for="exampleFormControlInput2" class="form-label">Email</label>
                <input value="<%= user.email %>" type="email" name="email" class="form-control"
                    id="exampleFormControlInput2" placeholder="name@example.com">
            </div>
            <div class="mb-3">
                <label for="exampleFormControlTextarea2" class="form-label">Address</label>
                <textarea name="address" class="form-control" id="exampleFormControlTextarea2"
                    rows="3"><%= user.address %></textarea>
            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-warning">Update</button>
            </div>
        </form>
    </div>
</body>

</html>